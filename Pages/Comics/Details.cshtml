@page
@model ProjectSuperhero.Pages.Comics.DetailsModel

@{
    ViewData["Title"] = Model.Comic.Name + " - Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-7 pe-md-5">
            <h1 class="text-primary mb-2">@Html.DisplayFor(model => model.Comic.Name)</h1>
            @if (!string.IsNullOrEmpty(Model.Comic.OtherName))
            {
                <h5 class="text-muted mb-4"><em>(@Html.DisplayFor(model => model.Comic.OtherName))</em></h5>
            }
            <hr class="border-secondary" />

            <dl class="row gap-y-2">
                <dt class="col-sm-4 uppercase small fw-bold">Series ID</label></dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Comic.SeriesId)</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Issue Number</dt>
                <dd class="col-sm-8">#@Html.DisplayFor(model => model.Comic.Number)</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Publisher</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Comic.Publisher)</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Writer</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Comic.Writer)</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Artist</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Comic.Artist)</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Genres</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary">@Html.DisplayFor(model => model.Comic.Genres)</span></dd>

                <dt class="col-sm-4 uppercase small fw-bold">Release Date</dt>
                <dd class="col-sm-8">@Model.Comic.ReleaseDate.ToString("MMMM dd, yyyy")</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Publication Date</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Comic.PublicationDate)</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Rating</dt>
                <dd class="col-sm-8">⭐ @Html.DisplayFor(model => model.Comic.Rating) / 10</dd>

                <dt class="col-sm-4 uppercase small fw-bold">Resource</dt>
                <dd class="col-sm-8"><a href="@Model.Comic.Resource" target="_blank" class="text-info">External Database Link</a></dd>
            </dl>

            @if (!string.IsNullOrEmpty(Model.Comic.Summary))
            {
                <div class="">
                    <h5 class=" card-title uppercase small mb-2 fw-bold">Summary</h5>
                    <p class="" style="line-height: 1.6;">@Html.DisplayFor(model => model.Comic.Summary)</p>
                </div>
            }

            <div class="mt-4 pt-2">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-page="./Edit" asp-route-id="@Model.Comic.Id" class="btn btn-primary px-4 me-2">Edit Details</a>
                }
                <a asp-page="./Index" class="btn btn-outline-secondary px-4">Back to List</a>
            </div>
        </div>

        <div class="col-md-5 mt-4 mt-md-0 text-center">
            <div class="sticky-top" style="top: 20px; z-index: 1;">
                @if (!string.IsNullOrEmpty(Model.Comic.Cover))
                {
                    <div class="p-2 bg-black rounded shadow" style="border: 3px solid var(--primary-hero); display: inline-block; max-width: 100%;">
                        <img src="../Images/@Model.Comic.Cover"
                             alt="Cover Art for @Model.Comic.Name"
                             class="img-fluid rounded"
                             style="max-height: 650px; width: auto; object-fit: contain; box-shadow: 0 10px 30px rgba(0,0,0,0.5);" />
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-items-center justify-content-center bg-black border border-secondary rounded p-5 text-muted" style="min-height: 450px;">
                        <i class="bi bi-image" style="font-size: 4rem;"></i>
                        <span class="mt-2">No Cover Art Available</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>