@page
@model ProjectSuperhero.Pages.Comics.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].SeriesId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Number)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Cover)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].ReleaseDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Resource)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Rating)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].OtherName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Genres)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Publisher)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Writer)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Artist)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].PublicationDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comic[0].Summary)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Comic) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SeriesId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Number)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cover)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Resource)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Rating)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OtherName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Genres)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Publisher)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Writer)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Artist)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PublicationDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Summary)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
