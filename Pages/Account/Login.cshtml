@page
@model ProjectSuperhero.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4 text-primary">Admin Sign In</h3>

                <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" autocomplete="off" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">Log In</button>
                </form>
            </div>
        </div>
    </div>
</div>