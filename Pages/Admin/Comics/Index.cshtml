@page
@model ProjectSuperhero.Pages.Comics.IndexModel

@{
    ViewData["Title"] = "Index";

    // --- Window Pagination Rendering Logic ---
    int maxVisiblePages = 5;
    int startPage = Math.Max(1, Model.CurrentPage - (maxVisiblePages / 2));
    int endPage = Math.Min(Model.TotalPages, startPage + maxVisiblePages - 1);

    if (endPage - startPage + 1 < maxVisiblePages)
    {
        startPage = Math.Max(1, endPage - maxVisiblePages + 1);
    }
}

<h1>Index</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</p>

@* Removed table-responsive wrapper and text-nowrap to make the grid completely static *@
<div class="shadow-sm rounded-3 border bg-white">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Cover)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Name)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Number)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Publisher)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Writer)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Artist)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Genres)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].ReleaseDate)</th>
                <th>@Html.DisplayNameFor(model => model.Comic[0].Rating)</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Comic)
            {
                <tr>
                    @* 1. Cover *@
                    <td>
                        @if (!string.IsNullOrEmpty(item.Cover))
                        {
                            <img src="~/Images/@item.Cover" alt="Cover" style="max-height: 45px; width: auto; border-radius: 4px;" />
                        }
                        else
                        {
                            <span class="text-muted small">No Cover</span>
                        }
                    </td>

                    @* 2. Name *@
                    <td>
                        <strong>@item.Name</strong>
                    </td>

                    @* 3. Number *@
                    <td>#@Html.DisplayFor(modelItem => item.Number)</td>

                    @* 4. Publisher *@
                    <td>@Html.DisplayFor(modelItem => item.Publisher)</td>

                    @* 5. Writer *@
                    <td>@Html.DisplayFor(modelItem => item.Writer)</td>

                    @* 6. Artist *@
                    <td>@Html.DisplayFor(modelItem => item.Artist)</td>

                    @* 7. Genres *@
                    <td>@Html.DisplayFor(modelItem => item.Genres)</td>

                    @* 8. ReleaseDate (Fixed compile error) *@
                    <td>
                        @item.ReleaseDate.ToString("yyyy-MM-dd")
                    </td>

                    @* 9. Rating *@
                    <td>⭐ @Html.DisplayFor(modelItem => item.Rating)</td>

                    @* Actions *@
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">Edit</a>
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info">Details</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* --- Pagination Control --- *@
@if (Model.TotalPages > 1)
{
    <nav aria-label="Admin catalog navigation" class="mt-4">
        <ul class="pagination pagination-sm justify-content-center flex-wrap">

            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="@(Model.CurrentPage - 1)" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="1">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link bg-light text-muted">...</span></li>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link @(i == Model.CurrentPage ? "bg-primary text-white border-primary" : "bg-light text-dark")" asp-page="./Index" asp-route-pageIndex="@i">@i</a>
                </li>
            }

            @if (endPage < Model.TotalPages)
            {
                @if (endPage < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link bg-light text-muted">...</span></li>
                }
                <li class="page-item">
                    <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="@Model.TotalPages">@Model.TotalPages</a>
                </li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="@(Model.CurrentPage + 1)" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}