@page
@model ProjectSuperhero.Pages.CatalogModel
@{
    ViewData["Title"] = "Comic Catalog";
    string currentLetter = ViewData["CurrentLetter"] as string;
}

<h2 class="mb-4">Comic Catalog</h2>

<div class="d-flex flex-wrap gap-1 mb-4">
    <a href="?" class="btn btn-sm @(string.IsNullOrEmpty(currentLetter) ? "btn-primary" : "btn-outline-primary")">All</a>

    @foreach (char c in "ABCDEFGHIJKLMNOPQRSTUVWXYZ")
    {
        string letterString = c.ToString();
        <a href="?letter=@letterString"
           class="btn btn-sm @(currentLetter == letterString ? "btn-primary active" : "btn-outline-primary")">
            @letterString
        </a>
    }
</div>

@if (!Model.Comics.Any())
{
    <div class="alert alert-info">No comics found starting with the letter "@currentLetter".</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Cover</th>
                <th>Name</th>
                <th>Issue #</th>
                <th>Publisher</th>
                <th>Release Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Comics)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Cover))
                        {
                            <img src="Images/@item.Cover" alt="Cover" style="max-height: 60px; width: auto; border-radius: 4px;" />
                        }
                        else
                        {
                            <span class="text-muted">No Cover</span>
                        }
                    </td>
                    <td>
                        <strong>@item.Name</strong>
                        @if (!string.IsNullOrEmpty(item.OtherName))
                        {
                            <br />
                
                            <small class="text-muted">(@item.OtherName)</small>
                        }
                    </td>
                    <td>#@item.Number</td>
                    <td>@item.Publisher</td>
                    <td>@item.ReleaseDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info">Details</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}