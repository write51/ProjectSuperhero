@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";

    // --- Pagination Window Logic ---
    int maxVisiblePages = 5;
    int startPage = Math.Max(1, Model.CurrentPage - (maxVisiblePages / 2));
    int endPage = Math.Min(Model.TotalPages, startPage + maxVisiblePages - 1);

    // Adjust start page if we are near the end of the page list
    if (endPage - startPage + 1 < maxVisiblePages)
    {
        startPage = Math.Max(1, endPage - maxVisiblePages + 1);
    }
}

<div class="container mt-4">
    <div class="row">

        <div class="col-md-9">
            <h4 class="uppercase small fw-bold mb-3">Latest added comics</h4>

            <div class="d-flex flex-wrap gap-4 justify-content-start">
                @foreach (var item in Model.Latest)
                {
                    <div class="text-center mb-3" style="width: 130px;">
                        <a href="Comics/Details?id=@item.Id" class="d-block p-1 bg-black rounded shadow-sm hover-zoom" style="border: 2px solid #333;">
                            <img height="156" width="120" src="Images/@item.Cover" alt="cover" class="img-fluid rounded" style="object-fit: cover;" />
                        </a>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-3">
                    <ul class="pagination pagination-sm justify-content-center flex-wrap">

                        @* Previous Button *@
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link bg-dark text-light border-secondary" asp-page="./Index" asp-route-pageIndex="@(Model.CurrentPage - 1)" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        @* First Page & Ellipsis if needed *@
                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link bg-dark text-light border-secondary" asp-page="./Index" asp-route-pageIndex="1">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link bg-dark text-muted border-secondary">...</span>
                                </li>
                            }
                        }

                        @* Dynamic Page Numbers Window *@
                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link @(i == Model.CurrentPage ? "bg-secondary border-secondary text-white" : "bg-dark text-light border-secondary")" asp-page="./Index" asp-route-pageIndex="@i">@i</a>
                            </li>
                        }

                        @* Last Page & Ellipsis if needed *@
                        @if (endPage < Model.TotalPages)
                        {
                            @if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link bg-dark text-muted border-secondary">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link bg-dark text-light border-secondary" asp-page="./Index" asp-route-pageIndex="@Model.TotalPages">@Model.TotalPages</a>
                            </li>
                        }

                        @* Next Button *@
                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link bg-dark text-light border-secondary" asp-page="./Index" asp-route-pageIndex="@(Model.CurrentPage + 1)" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>

        <div class="col-md-3 mt-4 mt-md-0 border-start border-secondary ps-md-4">
            <h4 class="uppercase small fw-bold mb-3">Genres</h4>

            <div class="list-group list-group-flush">
                <a href="/Search?Genre=Action" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Action</a>
                <a href="/Search?Genre=Adventure" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Adventure</a>
                <a href="/Search?Genre=Drama" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Drama</a>
                <a href="/Search?Genre=Fantasy" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Fantasy</a>
                <a href="/Search?Genre=Horror" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Horror</a>
                <a href="/Search?Genre=Medieval" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Medieval</a>
                <a href="/Search?Genre=Sci-Fi" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Sci-Fi</a>
                <a href="/Search?Genre=Superpowers" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Superpowers</a>
            </div>
        </div>

    </div>
</div>