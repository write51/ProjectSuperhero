@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";

    // --- Pagination Window Logic ---
    int maxVisiblePages = 5;
    int startPage = Math.Max(1, Model.CurrentPage - (maxVisiblePages / 2));
    int endPage = Math.Min(Model.TotalPages, startPage + maxVisiblePages - 1);

    if (endPage - startPage + 1 < maxVisiblePages)
    {
        startPage = Math.Max(1, endPage - maxVisiblePages + 1);
    }
}

<div class="container mt-4">
    <div class="row">

        <div class="col-md-9">
            <h4 class="uppercase small fw-bold mb-3">Latest added comics</h4>

            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
                @foreach (var item in Model.Latest)
                {
                    <div class="col">
                        <div class="card h-100 border shadow-sm position-relative text-dark"
                             style="transition: background-color 0.15s ease-in-out;"
                             onmouseover="this.style.backgroundColor='#f8f9ba';"
                             onmouseout="this.style.backgroundColor='#ffffff';">

                            @* Cover Image Container *@
                            @if (!string.IsNullOrEmpty(item.Cover))
                            {
                                <img src="~/Images/@item.Cover" class="card-img-top rounded-top" alt="@item.Name Cover" style="height: 200px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center border-bottom text-muted small rounded-top" style="height: 200px;">
                                    No Cover
                                </div>
                            }

                            @* Card Body Information Block *@
                            <div class="card-body p-2 d-flex flex-column justify-content-between">
                                <div class="mb-2">
                                    <h6 class="card-title mb-1 fw-bold text-dark">
                                        @item.Name
                                    </h6>
                                    <p class="card-text text-muted small mb-0">#@item.Number</p>
                                </div>

                                @* Stretched-link covers the entire .card container invisibly *@
                                <a asp-page="/Comics/Details" asp-route-id="@item.Id" class="stretched-link"></a>
                            </div>

                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-5">
                    <ul class="pagination pagination-sm justify-content-center flex-wrap">

                        @* Previous Button *@
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="@(Model.CurrentPage - 1)" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        @* First Page & Ellipsis if needed *@
                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="1">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link bg-light text-muted">...</span>
                                </li>
                            }
                        }

                        @* Dynamic Page Numbers Window *@
                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link @(i == Model.CurrentPage ? "bg-primary text-white border-primary" : "bg-light text-dark")" asp-page="./Index" asp-route-pageIndex="@i">@i</a>
                            </li>
                        }

                        @* Last Page & Ellipsis if needed *@
                        @if (endPage < Model.TotalPages)
                        {
                            @if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link bg-light text-muted">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="@Model.TotalPages">@Model.TotalPages</a>
                            </li>
                        }

                        @* Next Button *@
                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link bg-light text-dark" asp-page="./Index" asp-route-pageIndex="@(Model.CurrentPage + 1)" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>

        @* Genre Sidebar Navigation Block *@
        <div class="col-md-3 mt-4 mt-md-0 border-start ps-md-4">
            <h4 class="uppercase small fw-bold mb-3">Genres</h4>

            <div class="list-group list-group-flush">
                <a asp-page="/Genre" asp-route-genre="Action" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Action</a>
                <a asp-page="/Genre" asp-route-genre="Adventure" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Adventure</a>
                <a asp-page="/Genre" asp-route-genre="Drama" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Drama</a>
                <a asp-page="/Genre" asp-route-genre="Fantasy" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Fantasy</a>
                <a asp-page="/Genre" asp-route-genre="Horror" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Horror</a>
                <a asp-page="/Genre" asp-route-genre="Medieval" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Medieval</a>
                <a asp-page="/Genre" asp-route-genre="Sci-Fi" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Sci-Fi</a>
                <a asp-page="/Genre" asp-route-genre="Superpowers" class="list-group-item list-group-item-action bg-transparent border-secondary py-2 px-1">Superpowers</a>
            </div>
        </div>

    </div>
</div>